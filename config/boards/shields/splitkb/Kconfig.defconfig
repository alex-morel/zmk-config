if SHIELD_SPLITKB_LEFT

config ZMK_KEYBOARD_NAME
    default "Big Zero"

# Lado esquerdo = central (conecta no PC / host)
config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif

if SHIELD_SPLITKB_LEFT || SHIELD_SPLITKB_RIGHT

config ZMK_SPLIT
    default y

if ZMK_DISPLAY

config I2C
    default y

config SSD1306
    default y

# Tela CUSTOM em retrato via CANVAS rotacionado (nao usa rotacao de display,
# que trava OLED mono). Ver custom_status_screen.c.
choice ZMK_DISPLAY_STATUS_SCREEN
    default ZMK_DISPLAY_STATUS_SCREEN_CUSTOM
endchoice

# CRITICO (igual nice!view): desenho em canvas precisa de work queue dedicada
# (stack maior) e mem pool maior. Sem isso o custom screen trava/estoura no boot.
choice ZMK_DISPLAY_WORK_QUEUE
    default ZMK_DISPLAY_WORK_QUEUE_DEDICATED
endchoice

config ZMK_DISPLAY_DEDICATED_THREAD_STACK_SIZE
    default 4096

config LV_Z_MEM_POOL_SIZE
    default 8192

# Fontes usadas pela tela custom (cada tamanho = uma fonte)
config LV_FONT_MONTSERRAT_8
    default y

config LV_FONT_MONTSERRAT_16
    default y

config LV_USE_CANVAS
    default y

endif # ZMK_DISPLAY

if LVGL

config LV_Z_VDB_SIZE
    default 100

config LV_DPI_DEF
    default 148

config LV_Z_BITS_PER_PIXEL
    default 1

choice LV_COLOR_DEPTH
    default LV_COLOR_DEPTH_1
endchoice

endif # LVGL

endif
