#include <dt-bindings/zmk/matrix_transform.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/adc/nrf-saadc-v2.h>
#include <input/processors.dtsi>   // define os &zip_* (input processors, ex.: scroll)

/*
 * Teclado split custom (nRF52840 / nice!nano). 23 teclas por lado.
 * Matriz elétrica 6 colunas × 4 linhas (24 slots, 23 usados).
 *
 * PINAGEM (igual nos dois lados):
 *   Linhas (4):  D4, D5, D6, D7      -> pro_micro 4,5,6,7  (entradas, pull-down)
 *   Colunas (6): D8, D9, D10, D16, D18, D21 (saídas)   [reversas no lado direito]
 *   OLED I2C:    pro_micro_i2c = D2 (SDA) / D3 (SCL)
 *   Joystick:    X = D19 (AIN0),  Y = D20 (AIN5)
 *   Livres:      D0, D1, D14, D15
 *
 * Diodos: col2row (catodo da tecla apontando para a LINHA).
 *
 * Mapa físico por lado (6 colunas C0..C5 = mindinho->índice, + 3 polegares):
 *   C0,C1,C2,C5 -> 3 teclas (linhas 0,1,2)
 *   C3,C4       -> 4 teclas (linhas 0,1,2,3)  (índice alcança +1 fileira)
 *   Polegares   -> linha 3 das colunas C0,C1,C2
 *   (slot vazio: linha 3 da coluna C5)
 */

/ {
    chosen {
        zmk,kscan = &kscan0;
        /* ZMK Studio exige physical-layout e NAO aceita zmk,matrix-transform */
        zmk,physical-layout = &default_layout;
        zephyr,display = &oled;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        // Esquerda (cols 0-5)                              Direita (cols 6-11)
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)   RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)   RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)   RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
        RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)   RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)
        >;
        // Linha 3 (por lado): [pol0 pol1 pol2 idx-extra-C3 idx-extra-C4]
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
        row-gpios
            = <&pro_micro 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
        // col-gpios definidas em splitkb_left.overlay / splitkb_right.overlay
    };

    /*
     * Joystick DIREITO (periférica): os eventos vão pro central pela split
     * via input-split. O listener (no central) reporta como mouse; na layer 1
     * o processor transforma o movimento em SCROLL.
     */
    splits {
        #address-cells = <1>;
        #size-cells = <0>;
        jsr_split: jsr_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };
    };

    jsr_listener: jsr_listener {
        compatible = "zmk,input-listener";
        device = <&jsr_split>;
        status = "disabled";   // habilitado só no central (left overlay)

        scroller {
            layers = <1>;      // layer 1 -> joystick direito vira scroll
            input-processors = <&zip_xy_to_scroll_mapper>;
        };
    };
};

/*
 * ADC: canais dos eixos do joystick. Presentes nos dois lados.
 * Canal 0 = X = AIN0 (P0.02 / D19),  Canal 1 = Y = AIN5 (P0.29 / D20).
 */
&adc {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    channel@0 {
        reg = <0>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,input-positive = <NRF_SAADC_AIN0>;
        zephyr,resolution = <12>;
    };

    channel@1 {
        reg = <1>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,input-positive = <NRF_SAADC_AIN5>;
        zephyr,resolution = <12>;
    };
};

/* OLED SSD1306 no barramento I2C do pro_micro (D2 SDA / D3 SCL). */
&pro_micro_i2c {
    status = "okay";

    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <32>;          /* Se sua OLED for 0.96" 128x64, mude p/ 64 e multiplex p/ 63 */
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <31>; /* 31 p/ 128x32 ; 63 p/ 128x64 */
        segment-remap;
        com-invdir;
        com-sequential;
        prechargep = <0x22>;
    };
};

/* Physical layout (posicoes fisicas das teclas) — pro ZMK Studio.
 * Incluido no fim porque referencia &default_transform e &kscan0. */
#include "splitkb-layouts.dtsi"
