/*
 * Parte COMPARTILHADA entre as duas metades e o dongle.
 *
 * Aqui fica tudo que precisa ser IDENTICO nos tres: o matrix-transform (define
 * as posicoes do keymap), o physical-layout (ZMK Studio) e os nos de split dos
 * dois joysticks. Duplicar isso convidaria divergencia no mapa de teclas, entao
 * mora num lugar so.
 *
 * O que NAO esta aqui (por ser especifico de cada peca):
 *   - kscan real (matriz) ...... so nas metades (splitkb.dtsi)
 *   - kscan mock ............... so no dongle (nao tem teclas)
 *   - ADC + joystick local ..... nas metades
 *   - display (OLED vs GC9A01) . cada peca escolhe o seu zephyr,display
 *
 * ARQUITETURA COM DONGLE:
 *   dongle = central (roda o keymap, fala com o PC, tem a tela redonda)
 *   left/right = perifericos (cada um manda sua POSICAO ja transformada;
 *   o col-offset por lado deixa as posicoes unicas: esq 0-5, dir 6-11).
 *
 * JOYSTICKS via input-split:
 *   O roteamento do input-split e SO por 'reg' (tem que ser unico global):
 *     jsr_split reg=0  <- joystick DIREITO
 *     jsl_split reg=1  <- joystick ESQUERDO
 *   Cada periferico habilita SO o seu (com device=<&anin_...>); o outro fica
 *   disabled (input-split de periferico sem device = erro de build). No dongle,
 *   os dois ficam okay (modo central/proxy, sem device) e cada listener escuta
 *   o seu reg.
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <input/processors.dtsi>   // define os &zip_* (input processors, ex.: scroll)

/ {
    chosen {
        zmk,kscan = &kscan0;
        /* ZMK Studio exige physical-layout e NAO aceita zmk,matrix-transform */
        zmk,physical-layout = &default_layout;
        /* zephyr,display fica em cada peca (OLED nas metades, GC9A01 no dongle) */
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        // Esquerda (cols 0-5)                              Direita (cols 6-11)
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)   RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)   RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)   RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
        RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)   RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)
        >;
        // Linha 3 (por lado): [pol0 pol1 pol2 idx-extra-C3 idx-extra-C4]
    };

    /*
     * Nos de split dos dois joysticks. Ficam DISABLED por padrao; cada peca
     * habilita o que precisa (ver comentario do cabecalho).
     */
    splits {
        #address-cells = <1>;
        #size-cells = <0>;

        jsr_split: jsr_split@0 {          /* joystick DIREITO */
            compatible = "zmk,input-split";
            reg = <0>;
            status = "disabled";
        };

        jsl_split: jsl_split@1 {          /* joystick ESQUERDO */
            compatible = "zmk,input-split";
            reg = <1>;
            status = "disabled";
        };
    };

    /*
     * Listeners dos joysticks. Rodam no CENTRAL (dongle) — sao eles que geram
     * o HID de mouse. Ficam disabled aqui; o dongle habilita os dois.
     * Nas metades continuam disabled (a metade so ALIMENTA o input-split).
     */
    jsr_listener: jsr_listener {
        compatible = "zmk,input-listener";
        device = <&jsr_split>;
        status = "disabled";
        /* SCROLL FIXO, sem depender de camada -- processor no nivel base
         * do listener (nao num filho com "layers") roda em toda entrada,
         * incondicionalmente. Design antigo (troca por camada) documentado
         * errado na memoria do projeto; nunca foi a intencao real. */
        input-processors = <&zip_xy_to_scroll_mapper>;
    };

    jsl_listener: jsl_listener {
        compatible = "zmk,input-listener";
        device = <&jsl_split>;
        status = "disabled";   // cursor puro (sem processor)
    };
};

/* Physical layout (posicoes fisicas) — referencia &default_transform e &kscan0.
 * Incluido no fim porque depende dos dois. */
#include "splitkb-layouts.dtsi"
