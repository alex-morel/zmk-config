/*
 * Physical layout do "The Big Zero" — necessario pro ZMK Studio.
 * Posicoes geradas a partir das coordenadas reais do keyboard_base_plate_left.scad
 * (pitch choc 19mm -> 100 centi-keyunits). Ordem = mesma do default_transform.
 *
 * Layout: 6 colunas x 3 fileiras por lado + 2 teclas extras de indice + 3 polegares.
 */

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "The Big Zero";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0   63       0     0     0>
            , <&key_physical_attrs 100 100  100   63       0     0     0>
            , <&key_physical_attrs 100 100  200   11       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   11       0     0     0>
            , <&key_physical_attrs 100 100  500   26       0     0     0>
            , <&key_physical_attrs 100 100  900   26       0     0     0>
            , <&key_physical_attrs 100 100 1000   11       0     0     0>
            , <&key_physical_attrs 100 100 1100    0       0     0     0>
            , <&key_physical_attrs 100 100 1200   11       0     0     0>
            , <&key_physical_attrs 100 100 1300   63       0     0     0>
            , <&key_physical_attrs 100 100 1400   63       0     0     0>

            , <&key_physical_attrs 100 100    0  163       0     0     0>
            , <&key_physical_attrs 100 100  100  163       0     0     0>
            , <&key_physical_attrs 100 100  200  111       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  111       0     0     0>
            , <&key_physical_attrs 100 100  500  126       0     0     0>
            , <&key_physical_attrs 100 100  900  126       0     0     0>
            , <&key_physical_attrs 100 100 1000  111       0     0     0>
            , <&key_physical_attrs 100 100 1100  100       0     0     0>
            , <&key_physical_attrs 100 100 1200  111       0     0     0>
            , <&key_physical_attrs 100 100 1300  163       0     0     0>
            , <&key_physical_attrs 100 100 1400  163       0     0     0>

            , <&key_physical_attrs 100 100    0  258       0     0     0>
            , <&key_physical_attrs 100 100  100  258       0     0     0>
            , <&key_physical_attrs 100 100  200  211       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  211       0     0     0>
            , <&key_physical_attrs 100 100  500  226       0     0     0>
            , <&key_physical_attrs 100 100  900  226       0     0     0>
            , <&key_physical_attrs 100 100 1000  211       0     0     0>
            , <&key_physical_attrs 100 100 1100  200       0     0     0>
            , <&key_physical_attrs 100 100 1200  211       0     0     0>
            , <&key_physical_attrs 100 100 1300  258       0     0     0>
            , <&key_physical_attrs 100 100 1400  258       0     0     0>

            , <&key_physical_attrs 100 100  616  237       0     0     0>
            , <&key_physical_attrs 100 100  484  447       0     0     0>
            , <&key_physical_attrs 100 100  600  500       0     0     0>
            , <&key_physical_attrs 100 100  300  311       0     0     0>
            , <&key_physical_attrs 100 100  400  311       0     0     0>
            , <&key_physical_attrs 100 100  784  237       0     0     0>
            , <&key_physical_attrs 100 100 1000  311       0     0     0>
            , <&key_physical_attrs 100 100 1100  311       0     0     0>
            , <&key_physical_attrs 100 100  916  447       0     0     0>
            , <&key_physical_attrs 100 100  800  500       0     0     0>
            ;
    };
};
